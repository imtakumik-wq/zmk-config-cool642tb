  / {
        trackball_listener {
            compatible = "zmk,input-listener";
            device = <&trackball>;

            // レイヤー3の時：スクロールにする
            scroll_layer {
                layers = <3>;
                input-processors = <&zip_xy_to_scroll_mapper>;
            };

            // それ以外のレイヤー：マウス移動にする（明示的に指定）
            mouse_layer {
                layers = <0 1 2 4 5 6>;
                input-processors = <&zip_xy_to_mouse_mapper>;
            };
        };
    };

